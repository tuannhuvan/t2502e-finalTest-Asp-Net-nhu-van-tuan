@model T2502E_Comicsys.Models.Rentals

@{
    ViewData["Title"] = "Xóa Đơn Thuê";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Xóa Đơn Thuê</h1>
<h3>Bạn có chắc chắn muốn xóa đơn thuê này không?</h3>
<div>
    <h4>Thông tin đơn thuê</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-3 fw-bold">Khách hàng</dt>
        <dd class="col-sm-9">
            @if (Model?.Customer != null)
            {
                @Html.DisplayFor(model => model.Customer!.FullName)
            }
            else
            {
                <span class="text-muted">Không xác định</span>
            }
        </dd>
        
        <dt class="col-sm-3 fw-bold">Ngày thuê</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.RentalDate)</dd>
        
        <dt class="col-sm-3 fw-bold">Ngày trả dự kiến</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.ReturnDate)</dd>
        
        <dt class="col-sm-3 fw-bold">Trạng thái</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.Status)</dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="RentalID" />
        <input type="submit" value="Xóa luôn" class="btn btn-danger" /> |
        <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
    </form>
</div>